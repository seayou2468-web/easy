prefix=/Users/jenkins/Jenkins/workspace/ios-toolchain/ios/armv7
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: FluidSynth
Description: Software SoundFont synth
Version: 2.5.3
Requires.private: 
Libs: -L${libdir} -lfluidsynth
Libs.private: -lm -Wl,-framework,CoreAudio,-framework,AudioToolbox,-framework,AVFoundation -Wl,-framework,CoreFoundation,-framework,CoreMIDI,-framework,CoreServices
Cflags: -I${includedir}
