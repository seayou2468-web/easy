prefix=/Users/jenkins/Jenkins/workspace/ios-toolchain/ios/armv7
includedir=${prefix}/include
libdir=${prefix}/lib

Name: harfbuzz-gpu
Description: HarfBuzz GPU rasterization library
Version: 14.1.0
Requires: freetype2 >=  12.0.6, harfbuzz =  14.1.0
